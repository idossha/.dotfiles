#!/usr/bin/env python3
"""Codex Stop hook for curated Obsidian agent memory."""

from __future__ import annotations

import datetime as dt
import json
import os
from pathlib import Path
import subprocess
import sys


DOTFILES = Path.home() / ".dotfiles"
REMEMBER = DOTFILES / "agent/scripts/remember"
CODEX = "/opt/homebrew/bin/codex"
MAX_TRANSCRIPT_CHARS = 80_000
TIMEOUT_SECONDS = 150


def read_stdin_json() -> dict:
    raw = sys.stdin.read()
    if not raw.strip():
        return {}
    try:
        data = json.loads(raw)
    except json.JSONDecodeError:
        return {"raw_input": raw[:4000]}
    return data if isinstance(data, dict) else {"input": data}


def tail_text(path: Path, max_chars: int) -> str:
    try:
        text = path.read_text(encoding="utf-8", errors="ignore")
    except OSError:
        return ""
    if len(text) <= max_chars:
        return text
    return text[-max_chars:]


def hook_context(data: dict) -> dict:
    transcript_path = data.get("transcript_path")
    transcript_tail = ""
    if isinstance(transcript_path, str) and transcript_path:
        transcript_tail = tail_text(Path(transcript_path).expanduser(), MAX_TRANSCRIPT_CHARS)

    return {
        "hook_event_name": data.get("hook_event_name"),
        "source": data.get("source"),
        "turn_id": data.get("turn_id"),
        "cwd": data.get("cwd") or data.get("current_working_directory") or os.getcwd(),
        "prompt": data.get("prompt"),
        "last_assistant_message": data.get("last_assistant_message"),
        "transcript_path": transcript_path,
        "transcript_tail": transcript_tail,
    }


def classifier_prompt(context: dict) -> str:
    context_json = json.dumps(context, ensure_ascii=False, indent=2)
    return f"""Review this Codex Stop-hook context and decide whether to write one Obsidian memory.

Context JSON:
{context_json}

Rules:
- Write memory only for durable, crystallized knowledge a human should reuse later.
- Good candidates: stable user preferences, reusable repo/harness decisions, cross-session project facts, recurring gotchas.
- Do not write secrets, credentials, private personal data, raw logs, telemetry, chronological summaries, or noisy task status.
- Do not write project-specific implementation state unless it is clearly reusable beyond the current turn.
- If no memory should be written, output exactly: {{"write": false}}
- If memory should be written, output exactly one compact JSON object:
  {{"write": true, "topic": "short topic", "message": "one concise durable memory"}}
- Output JSON only, with no markdown.
"""


def run_classifier(context: dict) -> dict:
    try:
        result = subprocess.run(
            [
                CODEX,
                "exec",
                "--disable",
                "hooks",
                "--ask-for-approval",
                "never",
                "--sandbox",
                "read-only",
                classifier_prompt(context),
            ],
            cwd=context.get("cwd") or os.getcwd(),
            text=True,
            stdout=subprocess.PIPE,
            stderr=subprocess.PIPE,
            timeout=TIMEOUT_SECONDS,
            check=False,
        )
    except (OSError, subprocess.TimeoutExpired):
        return {"write": False}

    if result.returncode != 0:
        return {"write": False}

    stdout = result.stdout.strip()
    start = stdout.find("{")
    end = stdout.rfind("}")
    if start == -1 or end == -1 or end < start:
        return {"write": False}

    try:
        parsed = json.loads(stdout[start : end + 1])
    except json.JSONDecodeError:
        return {"write": False}
    return parsed if isinstance(parsed, dict) else {"write": False}


def remember(decision: dict, context: dict) -> None:
    if decision.get("write") is not True:
        return

    topic = str(decision.get("topic") or "").strip()
    message = str(decision.get("message") or "").strip()
    if not topic or not message:
        return

    source_parts = ["codex-stop-hook"]
    if context.get("turn_id"):
        source_parts.append(str(context["turn_id"]))
    source_parts.append(dt.date.today().isoformat())

    subprocess.run(
        [
            str(REMEMBER),
            "crystal",
            "--topic",
            topic,
            "--message",
            message,
            "--source",
            ":".join(source_parts),
        ],
        cwd=context.get("cwd") or os.getcwd(),
        stdout=subprocess.DEVNULL,
        stderr=subprocess.DEVNULL,
        timeout=20,
        check=False,
    )


def main() -> None:
    data = read_stdin_json()
    context = hook_context(data)
    decision = run_classifier(context)
    remember(decision, context)


if __name__ == "__main__":
    main()
